{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "App CLI",
      "request": "launch",
      "mainClass": "app.Main",
      "projectName": "compiler-app",
      "console": "integratedTerminal"
    },
    {
      "type": "java",
      "name": "App UI",
      "request": "launch",
      "mainClass": "app.MainApp",
      "projectName": "compiler-app",
      "console": "integratedTerminal",
      "vmArgs": "--module-path \"C:/javafx-sdk-21/lib\" --add-modules javafx.controls,javafx.fxml"
    },
    {
      "type": "java",
      "name": "Debug (Attach to Maven)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005
    }
  ]
}